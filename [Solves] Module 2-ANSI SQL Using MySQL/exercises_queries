SELECT u.user_id, u.full_name, e.event_id, e.title AS event_title, e.city, e.start_date
FROM Users u
JOIN Registrations r ON u.user_id = r.user_id
JOIN Events e ON r.event_id = e.event_id
WHERE e.status = 'upcoming' 
  AND u.city = e.city
ORDER BY e.start_date ASC;



SELECT e.event_id, e.title AS event_title, AVG(f.rating) AS average_rating
FROM Events e
JOIN Feedback f ON e.event_id = f.event_id
GROUP BY e.event_id, e.title
HAVING COUNT(f.feedback_id) >= 10
ORDER BY average_rating DESC;



SELECT user_id, full_name, email, registration_date
FROM Users
WHERE user_id NOT IN (
    SELECT DISTINCT user_id 
    FROM Registrations 
    WHERE registration_date >= DATE_SUB(CURDATE(), INTERVAL 90 DAY)
);



SELECT e.event_id, e.title AS event_title, COUNT(s.session_id) AS sessions_at_peak_hours
FROM Events e
LEFT JOIN Sessions s ON e.event_id = s.event_id 
  AND TIME(s.start_time) >= '10:00:00' 
  AND TIME(s.end_time) <= '12:00:00'
GROUP BY e.event_id, e.title;



SELECT u.city, COUNT(DISTINCT r.user_id) AS distinct_registered_users
FROM Users u
JOIN Registrations r ON u.user_id = r.user_id
GROUP BY u.city
ORDER BY distinct_registered_users DESC
LIMIT 5;



SELECT e.event_id, e.title AS event_title,
       SUM(CASE WHEN r.resource_type = 'pdf' THEN 1 ELSE 0 END) AS pdf_count,
       SUM(CASE WHEN r.resource_type = 'image' THEN 1 ELSE 0 END) AS image_count,
       SUM(CASE WHEN r.resource_type = 'link' THEN 1 ELSE 0 END) AS link_count,
       COUNT(r.resource_id) AS total_resources
FROM Events e
LEFT JOIN Resources r ON e.event_id = r.event_id
GROUP BY e.event_id, e.title;



SELECT u.user_id, u.full_name AS user_name, e.title AS event_name, f.rating, f.comments
FROM Feedback f
JOIN Users u ON f.user_id = u.user_id
JOIN Events e ON f.event_id = e.event_id
WHERE f.rating < 3;



SELECT e.event_id, e.title AS event_title, COUNT(s.session_id) AS scheduled_sessions_count
FROM Events e
LEFT JOIN Sessions s ON e.event_id = s.event_id
WHERE e.status = 'upcoming'
GROUP BY e.event_id, e.title;



SELECT u.user_id AS organizer_id, u.full_name AS organizer_name, e.status AS event_status, COUNT(e.event_id) AS total_events
FROM Users u
JOIN Events e ON u.user_id = e.organizer_id
GROUP BY u.user_id, u.full_name, e.status
ORDER BY organizer_name ASC, event_status ASC;



SELECT DISTINCT e.event_id, e.title AS event_title
FROM Events e
JOIN Registrations r ON e.event_id = r.event_id
LEFT JOIN Feedback f ON e.event_id = f.event_id
WHERE f.feedback_id IS NULL;



SELECT registration_date, COUNT(user_id) AS new_user_count
FROM Users
WHERE registration_date >= DATE_SUB(CURDATE(), INTERVAL 7 DAY)
GROUP BY registration_date
ORDER BY registration_date DESC;



SELECT e.event_id, e.title AS event_title, COUNT(s.session_id) AS session_count
FROM Events e
JOIN Sessions s ON e.event_id = s.event_id
GROUP BY e.event_id, e.title
HAVING COUNT(s.session_id) = (
    SELECT COUNT(session_id)
    FROM Sessions
    GROUP BY event_id
    ORDER BY COUNT(session_id) DESC
    LIMIT 1
);



SELECT e.city, AVG(f.rating) AS average_feedback_rating
FROM Events e
JOIN Feedback f ON e.event_id = f.event_id
GROUP BY e.city
ORDER BY average_feedback_rating DESC;



SELECT e.event_id, e.title AS event_title, COUNT(r.registration_id) AS total_registrations
FROM Events e
JOIN Registrations r ON e.event_id = r.event_id
GROUP BY e.event_id, e.title
ORDER BY total_registrations DESC
LIMIT 3;



SELECT s1.event_id, 
       s1.session_id AS session_id_a, s1.title AS session_title_a, s1.start_time AS start_time_a, s1.end_time AS end_time_a,
       s2.session_id AS session_id_b, s2.title AS session_title_b, s2.start_time AS start_time_b, s2.end_time AS end_time_b
FROM Sessions s1
JOIN Sessions s2 ON s1.event_id = s2.event_id AND s1.session_id < s2.session_id
WHERE s1.start_time < s2.end_time 
  AND s1.end_time > s2.start_time;



SELECT user_id, full_name, email, registration_date
FROM Users
WHERE registration_date >= DATE_SUB(CURDATE(), INTERVAL 30 DAY)
  AND user_id NOT IN (
      SELECT DISTINCT user_id 
      FROM Registrations
  );




SELECT speaker_name, COUNT(session_id) AS total_scheduled_sessions
FROM Sessions
GROUP BY speaker_name
HAVING COUNT(session_id) > 1
ORDER BY total_scheduled_sessions DESC;




SELECT event_id, title AS event_title, status
FROM Events
WHERE event_id NOT IN (
    SELECT DISTINCT event_id 
    FROM Resources
);



SELECT e.event_id, e.title AS event_title,
       COALESCE(reg.total_regs, 0) AS total_registrations,
       feed.avg_rating AS average_feedback_rating
FROM Events e
LEFT JOIN (
    SELECT event_id, COUNT(registration_id) AS total_regs
    FROM Registrations
    GROUP BY event_id
) reg ON e.event_id = reg.event_id
LEFT JOIN (
    SELECT event_id, AVG(rating) AS avg_rating
    FROM Feedback
    GROUP BY event_id
) feed ON e.event_id = feed.event_id
WHERE e.status = 'completed';




SELECT u.user_id, u.full_name,
       COALESCE(reg.events_attended, 0) AS events_attended,
       COALESCE(feed.feedbacks_submitted, 0) AS feedbacks_submitted
FROM Users u
LEFT JOIN (
    SELECT user_id, COUNT(registration_id) AS events_attended
    FROM Registrations
    GROUP BY user_id
) reg ON u.user_id = reg.user_id
LEFT JOIN (
    SELECT user_id, COUNT(feedback_id) AS feedbacks_submitted
    FROM Feedback
    GROUP BY user_id
) feed ON u.user_id = feed.user_id
ORDER BY events_attended DESC, feedbacks_submitted DESC;